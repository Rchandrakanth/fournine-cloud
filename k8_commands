    - containerPort: 8080
    
    
 apiVersion: v1
 kind: Service
 metadata: 
   name: application-service
 spec:
   type: NodePort
   selector:
     app: application
   ports:
   - port:80
     targetPort: 8080
     nodePort: 30008
     
     
