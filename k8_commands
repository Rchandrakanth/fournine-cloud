        app: application
    spec: 
      containers:
      - name: my-container
        image: chandu22727/application:latest
        ports:
        - containerPort: 8080


apiVersion: v1
kind: Pod
metadata:
  name: application-pod
  labels:
    app: application
spec:
  containers:
  - name: my-container
    image: chandu22727/application:latest
